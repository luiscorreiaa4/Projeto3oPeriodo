<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meu Painel - Nexus Inc.</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="shortcut icon" href="/img/favicon.ico" type="image/x-icon">
</head>
<body>
    
    <%- include('partials/nav') %>

    <main>
        <section class="contato-section dashboard-section">
            <div class="container-lettering dashboard-container">
                
                <h2 class="text-left">Bem-vindo(a), <span class="destaque-contato"><%= usuarioLogado.empresa %></span></h2>
                <p class="subtitulo text-left">Acompanhe o status dos seus serviços e diagnósticos.</p>
                
                <div class="dashboard-box contato-box">
                    <div class="dashboard-header">
                        <h3>Status do Diagnóstico Tecnológico</h3>
                        <span class="status-badge <%= usuarioLogado.status === 'Respondido' ? 'status-respondido' : 'status-pendente' %>">
                            <%= usuarioLogado.status === 'Respondido' ? 'Respondido' : 'Em Análise' %>
                        </span>
                    </div>

                    <div class="info-linha"><strong>Empresa:</strong> <%= usuarioLogado.empresa %></div>
                    <div class="info-linha"><strong>Desafio Registrado:</strong> <span class="tag-desafio" style="margin-top: 0;"><%= usuarioLogado.desafio %></span></div>

                    <% if (usuarioLogado.status === 'Respondido') { %>
                        <div class="resposta-box">
                            <h4><i class="fas fa-check-circle"></i> Diagnóstico Nexus:</h4>
                            <p><%= usuarioLogado.resposta_admin %></p>
                        </div>
                    <% } else { %>
                        <p class="mt-10"><em>Nossos consultores estão analisando seu desafio. Você receberá uma notificação assim que o diagnóstico estiver pronto.</em></p>
                    <% } %>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>

</body>
</html>