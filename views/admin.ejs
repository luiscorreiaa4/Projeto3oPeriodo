<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel Administrador - Nexus Inc.</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="shortcut icon" href="/img/favicon.ico" type="image/x-icon">
</head>
<body>
    
    <%- include('partials/nav') %>

    <main>
        <section class="dashboard-section">
            <div class="container-lettering dashboard-container">
                
                <h2 class="text-left">Gestão de <span class="destaque-contato">Leads</span></h2>
                <p class="text-left">Visualize e gerencie as empresas cadastradas na plataforma.</p>
                
                <div class="grid-clientes">
                    
                    <% clientes.forEach(function(cliente) { %>
                        
                        <div class="card-cliente">
                            <div class="card-cliente-header">
                                <h3><%= cliente.empresa %></h3>
                                <span class="status-badge <%= cliente.status === 'Respondido' ? 'status-respondido' : 'status-pendente' %>">
                                    <%= cliente.status%>
                                </span>
                            </div>
                            <div class="card-cliente-body">
                                <div class="info-linha"><strong>E-mail:</strong> <%= cliente.email %></div>
                                <div class="info-linha"><strong>Celular:</strong> <%= cliente.celular %></div>
                                <div class="info-linha"><strong>Data:</strong> <%= cliente.data %></div>
                            </div>
                            <span class="tag-desafio"><%= cliente.desafio %></span>
                            <a href="/admin/responder/<%= cliente.id %>" class="botao-solicitar botao-admin-card">
                                <%= cliente.status === 'Respondido' ? 'Editar Resposta' : 'Responder Cliente' %>
                            </a>
                        </div>

                    <% }); %>
                    
                </div>
            </div>
        </section>
    </main>

</body>
</html>