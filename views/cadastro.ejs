<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cadastro de Cliente - Nexus Inc.</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="shortcut icon" href="/img/favicon.ico" type="image/x-icon">
</head>
<body>
    
    <%- include('partials/nav') %>

    <main>
        <section id="cadastro" class="contato-section">
            <div class="container-lettering">
                
                <h2>Acesse o Portal de Clientes <span class="destaque-contato">Nexus</span></h2>
                <p>Cadastre sua empresa para solicitar diagnósticos, gerenciar serviços e acompanhar seus resultados.</p>
                
                <form class="contato-box" action="/cadastro" method="post" id="formCadastro" novalidate>
                    
                    <div class="texto-box">
                        <label for="empresa">Nome da empresa</label>
                        <input type="text" autocomplete="organization" id="empresa" name="empresa" placeholder="Ex: Alphabet Inc." required>
                        <span id="erro-empresa" class="mensagem-erro">Por favor, informe o nome da sua empresa.</span>
                    </div>
                    
                    <div class="texto-box">
                        <label for="email">E-mail corporativo</label>
                        <input type="email" autocomplete="email" id="email" name="email" placeholder="Ex: contato@empresa.com" required>
                        <span id="erro-email" class="mensagem-erro">Por favor, insira um e-mail válido (exemplo@dominio.com).</span>
                    </div>

                    <div class="texto-box">
                        <label for="celular">Celular / WhatsApp</label>
                        <input type="tel" autocomplete="tel" id="celular" name="celular" placeholder="(11) 99999-9999" maxlength="15" required>
                        <span id="erro-celular" class="mensagem-erro">Por favor, insira um número de telefone válido (com DDD).</span>
                    </div>

                    <div class="texto-box">
                        <label for="senha">Senha de Acesso</label>
                        <input type="password" autocomplete="new-password" id="senha" name="senha" pattern="(?=.*\d)(?=.*[a-z])(?=.*[A-Z]).{8,}" placeholder="Crie uma senha forte" required>
                        <small class="dica-senha">Mín. 8 caracteres, 1 maiúscula e 1 número.</small>
                        <span id="erro-padrao-senha" class="mensagem-erro">A senha digitada está muito fraca. Siga as regras acima.</span>
                    </div>

                    <div class="texto-box">
                        <label for="confirma_senha">Confirme sua senha</label>
                        <input type="password" autocomplete="new-password" id="confirma_senha" name="confirma_senha" placeholder="Digite a senha novamente" required>
                        <span id="erro-confirma-senha" class="mensagem-erro">As senhas não coincidem.</span>
                    </div>

                    <div class="texto-box">
                        <label for="desafio">Qual seu maior desafio tecnológico atual?</label>
                        <select id="desafio" name="desafio" required>
                            <option value="" disabled selected> - Selecione uma opção - </option>
                            <option value="custos">Reduzir custos operacionais</option>
                            <option value="automacao">Automatizar processos manuais</option>
                            <option value="seguranca">Segurança de dados e LGPD</option>
                            <option value="outro">Outro desafio estratégico</option>
                        </select>
                        <span id="erro-desafio" class="mensagem-erro">Por favor, selecione um desafio da lista.</span>
                    </div>
                    
                    <button type="submit" class="botao-solicitar">Finalizar Cadastro</button>
                    
                    <div class="box-link-login">
                        <p>Já possui uma conta? <a href="/login">Faça login aqui</a></p>
                    </div>
                </form>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>

    <script>
        const form = document.getElementById('formCadastro');
        const empresa = document.getElementById('empresa');
        const email = document.getElementById('email');
        const celular = document.getElementById('celular');
        const senha = document.getElementById('senha');
        const confirmaSenha = document.getElementById('confirma_senha');
        const desafio = document.getElementById('desafio');
        
        const erroEmpresa = document.getElementById('erro-empresa');
        const erroEmail = document.getElementById('erro-email');
        const erroCelular = document.getElementById('erro-celular');
        const erroPadraoSenha = document.getElementById('erro-padrao-senha');
        const erroConfirmaSenha = document.getElementById('erro-confirma-senha');
        const erroDesafio = document.getElementById('erro-desafio');

        function toggleErro(inputElement, spanElement, temErro) {
            if (temErro) {
                inputElement.classList.add('input-erro');
                spanElement.classList.add('ativo');
            } else {
                inputElement.classList.remove('input-erro');
                spanElement.classList.remove('ativo');
            }
        }

        empresa.addEventListener('focus', function() {
            toggleErro(empresa, erroEmpresa, false);
        });

        email.addEventListener('blur', function() {
            toggleErro(email, erroEmail, email.value !== '' && !email.checkValidity());
        });

        desafio.addEventListener('change', function() {
            toggleErro(desafio, erroDesafio, desafio.value === '');
        });

        celular.addEventListener('blur', function() {
            let v = celular.value.replace(/\D/g, ''); 
            
            // Formatação do celular
            if (v.length === 11) celular.value = `(${v.slice(0,2)}) ${v.slice(2,7)}-${v.slice(7,11)}`;
            else if (v.length === 10) celular.value = `(${v.slice(0,2)}) ${v.slice(2,6)}-${v.slice(6,10)}`;
            
            // Validação do celular
            toggleErro(celular, erroCelular, v.length > 0 && v.length < 10);
        });

        senha.addEventListener('blur', function() {
            toggleErro(senha, erroPadraoSenha, senha.value !== '' && !senha.checkValidity());
            checarSenhasIguais();
        });

        // Validação em tempo real (input)
        function checarSenhasIguais() {
            if (confirmaSenha.value !== '') {
                toggleErro(confirmaSenha, erroConfirmaSenha, senha.value !== confirmaSenha.value);
            }
        }
        confirmaSenha.addEventListener('input', checarSenhasIguais);

        // Barreira Final: Submit
        form.addEventListener('submit', function(event) {
            let temErro = false;

            // Executa as verificações
            const checkEmpresa = empresa.value.trim() === '';
            const checkEmail = !email.checkValidity() || email.value === '';
            const checkCelular = celular.value.replace(/\D/g, '').length < 10;
            const checkSenha = !senha.checkValidity() || senha.value === '';
            const checkConfirma = senha.value !== confirmaSenha.value || confirmaSenha.value === '';
            const checkDesafio = desafio.value === '';

            // Aplica as classes visualmente usando nossa função mestre
            if(checkEmpresa) toggleErro(empresa, erroEmpresa, true);
            if(checkEmail) toggleErro(email, erroEmail, true);
            if(checkCelular) toggleErro(celular, erroCelular, true);
            if(checkSenha) toggleErro(senha, erroPadraoSenha, true);
            if(checkConfirma) toggleErro(confirmaSenha, erroConfirmaSenha, true);
            if(checkDesafio) toggleErro(desafio, erroDesafio, true);

            // Consolida se há algum erro geral
            temErro = checkEmpresa || checkEmail || checkCelular || checkSenha || checkConfirma || checkDesafio;

            if (temErro) {
                event.preventDefault(); 
            }
        });
    </script>
</body>
</html>