<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meu Perfil - Nexus Inc.</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/cadastro.css">
    <link rel="shortcut icon" href="/img/favicon.ico" type="image/x-icon">
</head>
<body>
    
    <%- include('partials/nav') %>

    <main>
        <section class="contato-section">
            <div class="container-lettering">
                <h2>Editar <span class="destaque-contato">Perfil</span></h2>
                <p>Mantenha as informações da sua empresa atualizadas.</p>

                <% if (typeof mensagem !== 'undefined') { %>
                    <div class="alerta alerta-sucesso">
                        <%= mensagem %>
                    </div>
                <% } %>

                <form class="contato-box" action="/perfil" method="post" id="formPerfil" novalidate>
                    <div class="texto-box">
                        <label for="empresa">Nome da empresa</label>
                        <input type="text" id="empresa" name="empresa" value="<%= usuarioLogado.empresa %>" required>
                        <span id="erro-empresa" class="mensagem-erro">Informe o nome da empresa.</span>
                    </div>

                    <div class="texto-box">
                        <label for="email">E-mail corporativo</label>
                        <input type="email" id="email" name="email" value="<%= usuarioLogado.email %>" required>
                        <span id="erro-email" class="mensagem-erro">Insira um e-mail válido.</span>
                    </div>

                    <div class="texto-box">
                        <label for="celular">Celular / WhatsApp</label>
                        <input type="tel" id="celular" name="celular" value="<%= usuarioLogado.celular %>" required>
                        <span id="erro-celular" class="mensagem-erro">Mínimo de 10 dígitos.</span>
                    </div>

                    <div class="texto-box">
                        <label for="senha">Nova Senha (deixe em branco para manter a atual)</label>
                        <input type="password" id="senha" name="senha" pattern="(?=.*\d)(?=.*[a-z])(?=.*[A-Z]).{8,}" placeholder="Mín. 8 caracteres, 1 maiúscula e 1 número">
                        <span id="erro-padrao-senha" class="mensagem-erro">Senha muito fraca.</span>
                    </div>

                    <div class="texto-box">
                        <label for="confirma_senha">Confirme a Nova Senha</label>
                        <input type="password" id="confirma_senha" name="confirma_senha">
                        <span id="erro-confirma-senha" class="mensagem-erro">As senhas não coincidem.</span>
                    </div>

                    <div class="texto-box">
                        <label for="desafio">Seu desafio tecnológico</label>
                        <select id="desafio" name="desafio" required>
                            <option value="custos" <%= usuarioLogado.desafio === 'custos' ? 'selected' : '' %>>Reduzir custos operacionais</option>
                            <option value="automacao" <%= usuarioLogado.desafio === 'automacao' ? 'selected' : '' %>>Automatizar processos manuais</option>
                            <option value="seguranca" <%= usuarioLogado.desafio === 'seguranca' ? 'selected' : '' %>>Segurança de dados e LGPD</option>
                            <option value="outro" <%= usuarioLogado.desafio === 'outro' ? 'selected' : '' %>>Outro desafio estratégico</option>
                        </select>
                        <span id="erro-desafio" class="mensagem-erro">Selecione uma opção.</span>
                    </div>

                    <button type="submit" class="botao-solicitar">Salvar Alterações</button>
                </form>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>
    <script src="/js/validacaoperfil.js"></script>
</body>
</html>